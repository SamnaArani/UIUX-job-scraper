# ── اجباری ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── اختیاری: JSearch (RapidAPI) ─────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# ── اختیاری: Adzuna ──────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_API_KEY=your_adzuna_api_key

# ── اختیاری: Google Sheets ──────────────────────────────────────────────────
GSHEET_CREDENTIALS={"type":"service_account",...}
GSHEET_ID=your_google_sheet_id_here

# ── اختیاری: Cloudflare Worker ───────────────────────────────────────────────
CF_WORKER_URL=https://your-worker.workers.dev/jobs

# ── اختیاری: پروفایل کاربر ──────────────────────────────────────────────────
# مهارت‌هات رو comma-separated بنویس — اگه خالی باشه، پیش‌فرض‌ها استفاده میشن
USER_SKILLS=python, wordpress, technical seo, ahrefs, semrush, google analytics

# ── اختیاری: Cover Letter Prompt ─────────────────────────────────────────────
# اگه خالی بذاری، پرامپت پیش‌فرض استفاده میشه
# CL_PROMPT=Write a professional cover letter for {title} at {company}. Job link: {url}
